    "clsx": "^2.1.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.6.0",
    "oxlint-tsgolint": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.2",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
